{
  "expo": {
    "name": "Opportunity OS",
    "slug": "opportunity-os",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "opportunityos",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#020617"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.opportunityos.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#020617"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": ["expo-splash-screen", "expo-font"],
    "extra": {
      "eas": {
        "projectId": "93b0268b-7b93-4e4a-b1dc-a48ec2915864"
      }
    }
  }
}